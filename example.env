# ==========================================
# Teacher model configuration
# Used for DSPy query rewriting and Case 2 judge-style evaluation.
# Any OpenAI-compatible endpoint works (OpenAI, Azure, DashScope, Ollama, etc.)
# ==========================================

# Option A: OpenAI
TEACHER_MODEL_NAME="gpt-4o-mini"
TEACHER_API_KEY="your-openai-key"
TEACHER_API_BASE=""

# Option B: Qwen via DashScope
# TEACHER_MODEL_NAME="qwen3.5-plus"
# TEACHER_API_KEY="your-dashscope-key"
# TEACHER_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Option C: Local Ollama
# TEACHER_MODEL_NAME="llama3"
# TEACHER_API_KEY=""
# TEACHER_API_BASE="http://localhost:11434"

# ==========================================
# Student model configuration
# Used for answer generation in the RAG pipeline.
# Any OpenAI-compatible endpoint works.
# ==========================================

# Option A: OpenAI (recommended for evaluators)
STUDENT_MODEL_NAME="gpt-4o-mini"
STUDENT_API_KEY="your-openai-key"
STUDENT_API_BASE=""

# Option B: Qwen via DashScope
# STUDENT_MODEL_NAME="qwen3.5-35b-a3b"
# STUDENT_API_KEY="your-dashscope-key"
# STUDENT_API_BASE="https://dashscope.aliyuncs.com/compatible-mode/v1"

# Option C: Local Ollama
# STUDENT_MODEL_NAME="qwen2.5:1.5b"
# STUDENT_API_KEY=""
# STUDENT_API_BASE="http://localhost:11434"
